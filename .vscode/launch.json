    "version": "0.2.0",
    "configurations": [
        {
            
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "runtimeExecutable": "/Users/retorres/.nvm/versions/node/v22.18.0/bin/npm",
            "runtimeArgs": [
                "run",
                "start:debug"
            ],
            "env": {
                "STAGE": "dev",
                "NODE_ENV": "development",
                "PATH": "/Users/retorres/.nvm/versions/node/v22.18.0/bin:${env:PATH}"
            },
            "cwd": "${workspaceFolder}",
            "autoAttachChildProcesses": true,
            "restart": true,
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/src/app.module.ts",
            "preLaunchTask": "tsc: build - tsconfig.json",
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ],
            "sourceMaps": true,
            "stopOnEntry": false,
            "console": "integratedTerminal"
        }
    ]
}